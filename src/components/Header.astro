---
import { Icon } from 'astro-icon/components'

const navItems = [
  { label: "ホーム", href: "/", icon: "lucide:home" },
  { label: "自己紹介", href: "/about", icon: "lucide:user" },
  { label: "スキル", href: "/skills", icon: "lucide:briefcase" },
  { label: "作品", href: "/works", icon: "lucide:palette" },
  { label: "お知らせ", href: "/news", icon: "lucide:megaphone" },
  { label: "お問い合わせ", href: "/contact", icon: "lucide:mail" },
]
---

<header class="bg-white border-b border-gray-200">
  <nav class="max-w-3xl mx-auto px-4 py-3 md:px-6">
    <ul class="flex flex-wrap gap-x-5 gap-y-2">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-indigo-600 transition-colors"
          >
            <Icon name={item.icon} class="w-4 h-4" />
            <span>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>