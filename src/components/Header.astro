---
import { Icon } from 'astro-icon/components'

const navItems = [
  { label: "ホーム", href: "/", icon: "lucide:home" },
  { label: "自己紹介", href: "/about", icon: "lucide:user" },
  { label: "スキル", href: "/skills", icon: "lucide:briefcase" },
  { label: "作品", href: "/works", icon: "lucide:palette" },
  { label: "お問い合わせ", href: "/contact", icon: "lucide:mail" },
]
---

<header class="header">
  <nav class="nav">
    {navItems.map((item) => (
      <a href={item.href} class="nav-link">
        <Icon name={item.icon} class="nav-icon" />
        <span>{item.label}</span>
      </a>
    ))}
  </nav>
</header>

<style>
  .header {
    background-color: #fff;
    border-bottom: 1px solid #eee;
    padding: 1rem 2rem;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: #555;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: #4f39fa;
  }

  .nav-icon {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 600px) {
    .nav {
      flex-wrap: wrap;
      gap: 0.75rem;
    }
  }
</style>