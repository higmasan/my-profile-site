---
interface Props {
  title: string
}

const { title } = Astro.props
---

<article class="media-card">
  <div class="media-card-image">
    <slot name="image" />
  </div>
  <div class="media-card-body">
    <h3 class="media-card-title">{title}</h3>
    <slot />
  </div>
  <div class="media-card-footer">
    <slot name="footer" />
  </div>
</article>

<style>
  .media-card {
    background-color: #fff;
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
  }

  .media-card-image {
    background-color: #f0f0f0;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .media-card-body {
    padding: 1.5rem;
  }

  .media-card-title {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .media-card-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid #eee;
  }
</style>