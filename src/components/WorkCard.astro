---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  title: string
  description: string
  tags: string[]
  year: number
  image?: ImageMetadata
}

const { title, description, tags, year, image } = Astro.props
---

<article class="bg-white border border-gray-200 rounded-xl overflow-hidden transition-shadow hover:shadow-lg">
  {image && (
    <div class="overflow-hidden">
      <Image
        src={image}
        alt={title}
        width={600}
        class="w-full h-48 object-cover transition-transform duration-300 hover:scale-105"
      />
    </div>
  )}
  <div class="p-5">
    <h2 class="text-lg font-bold mb-1">{title}</h2>
    <p class="text-gray-500 text-sm leading-relaxed mb-3">{description}</p>
    <div class="flex flex-wrap gap-2 mb-2">
      {tags.map((tag) => (
        <span class="bg-indigo-50 text-indigo-600 text-xs px-3 py-1 rounded-full">
          {tag}
        </span>
      ))}
    </div>
    <p class="text-gray-400 text-xs">{year}年</p>
  </div>
</article>