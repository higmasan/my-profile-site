---
const name = "田中太郎"
const pageTitle = `ページが見つかりません - ${name}のサイト`
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main class="container">
      <div class="error-content">
        <p class="error-code">404</p>
        <h1>ページが見つかりません</h1>
        <p class="error-message">
          お探しのページは存在しないか、移動した可能性があります。
        </p>
        <a href="/" class="home-link">🏠 トップページに戻る</a>
      </div>
    </main>
  </body>
</html>

<style>
  .container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    font-family: "Helvetica Neue", Arial, "Hiragino Sans",
      "Hiragino Kaku Gothic ProN", Meiryo, sans-serif;
  }

  .error-content {
    text-align: center;
    padding: 2rem;
  }

  .error-code {
    font-size: 6rem;
    font-weight: bold;
    color: #ddd;
    line-height: 1;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 1.5rem;
    color: #333;
    margin-bottom: 1rem;
  }

  .error-message {
    color: #888;
    margin-bottom: 2rem;
  }

  .home-link {
    display: inline-block;
    padding: 0.75rem 2rem;
    background-color: #4f39fa;
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    transition: background-color 0.2s;
  }

  .home-link:hover {
    background-color: #3d2bc7;
  }
</style>