---
import BaseLayout from '../layouts/BaseLayout.astro'

const name = "田中太郎"
const job = "Web開発者"
const location = "東京"
const bio = `
  2020年からWeb開発を始めました。
  フロントエンドの技術を中心に、
  使いやすく美しいWebサイトを作ることを目指しています。
`.trim()
---

<BaseLayout title="自己紹介 - 田中太郎のサイト">
  <h1>自己紹介</h1>

  <div class="profile">
    <h2>{name}</h2>
    <p class="job">{job}</p>
    <p class="location">📍 {location}</p>
  </div>

  <div class="bio">
    <h2>経歴</h2>
    <p>{bio}</p>
  </div>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    color: #4f39fa;
    margin-bottom: 1.5rem;
  }

  .profile {
    margin-bottom: 2rem;
  }

  .profile h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .job {
    color: #666;
    font-size: 1.1rem;
  }

  .location {
    color: #888;
    margin-top: 0.25rem;
  }

  .bio {
    margin-bottom: 2rem;
  }

  .bio h2 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #4f39fa;
  }

  .bio p {
    color: #555;
    line-height: 1.8;
    white-space: pre-line;
  }
</style>