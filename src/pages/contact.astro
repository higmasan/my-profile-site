---
import BaseLayout from '../layouts/BaseLayout.astro'

const email = "example@example.com"
---

<BaseLayout title="お問い合わせ - 田中太郎のサイト">
  <h1>お問い合わせ</h1>

  <div class="contact-info">
    <p>お仕事のご依頼・ご相談は、以下の方法でお気軽にご連絡ください。</p>

    <div class="contact-methods">
      <div class="contact-method">
        <h2>✉️ メール</h2>
        <p><a href={`mailto:${email}`}>{email}</a></p>
      </div>

      <div class="contact-method">
        <h2>💬 SNS</h2>
        <p><a href="https://twitter.com/" target="_blank" rel="noopener noreferrer">X (Twitter)</a></p>
        <p><a href="https://github.com/" target="_blank" rel="noopener noreferrer">GitHub</a></p>
      </div>
    </div>
  </div>

  <div class="form-placeholder">
    <p>📝 お問い合わせフォームは準備中です。</p>
  </div>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    color: #4f39fa;
    margin-bottom: 1.5rem;
  }

  .contact-info {
    margin-bottom: 2rem;
  }

  .contact-info > p {
    color: #555;
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .contact-methods {
    display: grid;
    gap: 1.5rem;
  }

  .contact-method {
    background-color: #fff;
    border: 1px solid #eee;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .contact-method h2 {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .contact-method a {
    color: #4f39fa;
    text-decoration: none;
  }

  .contact-method a:hover {
    text-decoration: underline;
  }

  .contact-method p {
    margin-bottom: 0.25rem;
  }

  .form-placeholder {
    background-color: #f8f8f8;
    border: 2px dashed #ddd;
    border-radius: 12px;
    padding: 3rem;
    text-align: center;
    color: #888;
  }

  @media (min-width: 600px) {
    .contact-methods {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>