---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Image } from 'astro:assets'
import profileImage from '../assets/images/profile.jpg'

const skills = [
  { name: "HTML", icon: "📄" },
  { name: "CSS", icon: "🎨" },
  { name: "JavaScript", icon: "⚡" },
  { name: "Astro.js", icon: "🚀" },
  { name: "Git", icon: "🔀" },
]

const isAvailable = true

const postFiles = import.meta.glob('./news/*.md', { eager: true })
const allPosts = Object.values(postFiles) as any[]
const latestPosts = allPosts
  .sort((a, b) => {
    const dateA = new Date(a.frontmatter.date)
    const dateB = new Date(b.frontmatter.date)
    return dateB.getTime() - dateA.getTime()
  })
  .slice(0, 3)
---

<BaseLayout title="田中太郎のサイト">
  <!-- ヒーローセクション -->
  <section class="text-center py-12">
    <div class="mb-6">
      <Image
        src={profileImage}
        alt="田中太郎のプロフィール写真"
        width={200}
        class="rounded-full border-4 border-indigo-100 mx-auto"
      />
    </div>
    <h1 class="text-2xl md:text-3xl font-bold text-indigo-600 mb-2">
      こんにちは、田中太郎です！
    </h1>
    <p class="text-lg text-gray-500">Web開発者</p>
  </section>

  <!-- 紹介文 -->
  <section class="py-6">
    <p class="text-gray-600 leading-relaxed">
      Webサイトの制作をしています。
      HTML/CSS/JavaScriptを使ったフロントエンド開発が得意です。
      最近はAstro.jsを使ったサイト構築に興味があります。
    </p>
  </section>

  <!-- スキル -->
  <section class="py-6">
    <h2 class="text-xl font-bold mb-4 pb-2 border-b-2 border-indigo-600">
      スキル
    </h2>
    <div class="flex flex-wrap gap-3">
      {skills.map((skill) => (
        <div
          class="flex items-center gap-2 bg-white border border-gray-200
                rounded-lg px-4 py-2 text-sm transition-shadow hover:shadow-md"
        >
          <span>{skill.icon}</span>
          <span>{skill.name}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- お知らせ -->
  <section class="py-6">
    <h2 class="text-xl font-bold mb-4 pb-2 border-b-2 border-indigo-600">
      お知らせ
    </h2>
    <div class="flex flex-col gap-3 mb-4">
      {latestPosts.map((post) => (
        <a href={post.url}
           class="flex items-center gap-4 p-4 bg-white border border-gray-200
                  rounded-lg no-underline text-inherit transition-shadow hover:shadow-md">
          <time class="text-gray-400 text-sm whitespace-nowrap">
            {post.frontmatter.date}
          </time>
          <span class="text-gray-800 text-sm hover:text-indigo-600">
            {post.frontmatter.title}
          </span>
        </a>
      ))}
    </div>
    <div class="text-right">
      <a href="/news" class="text-indigo-600 text-sm no-underline hover:underline">
        すべてのお知らせを見る →
      </a>
    </div>
  </section>

  <!-- お仕事募集中 -->
  {isAvailable && (
    <section class="mt-8 p-6 bg-indigo-50 rounded-xl text-center">
      <p class="text-indigo-600 font-bold">
        📢 お仕事募集中！お気軽にお問い合わせください。
      </p>
    </section>
  )}
</BaseLayout>