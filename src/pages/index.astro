---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Image } from 'astro:assets'
import profileImage from '../assets/images/profile.jpg'

const skills = [
  { name: "HTML", icon: "📄" },
  { name: "CSS", icon: "🎨" },
  { name: "JavaScript", icon: "⚡" },
  { name: "Astro.js", icon: "🚀" },
  { name: "Git", icon: "🔀" },
]

const isAvailable = true

// 最新のお知らせ3件を取得
const postFiles = import.meta.glob('./news/*.md', { eager: true })
const allPosts = Object.values(postFiles) as any[]
const latestPosts = allPosts
  .sort((a, b) => {
    const dateA = new Date(a.frontmatter.date)
    const dateB = new Date(b.frontmatter.date)
    return dateB.getTime() - dateA.getTime()
  })
  .slice(0, 3)
---

<BaseLayout title="田中太郎のサイト">
  <!-- 自己紹介セクション -->
  <section class="hero">
    <div class="hero-image">
      <Image
        src={profileImage}
        alt="田中太郎のプロフィール写真"
        width={200}
        class="profile-photo"
      />
    </div>
    <h1 class="hero-title">こんにちは、田中太郎です！</h1>
    <p class="hero-subtitle">Web開発者</p>
  </section>

  <!-- 以下、紹介文・スキル・お仕事募集中は前章と同じ -->
  <section class="about">
    <p class="about-text">
      Webサイトの制作をしています。
      HTML/CSS/JavaScriptを使ったフロントエンド開発が得意です。
      最近はAstro.jsを使ったサイト構築に興味があります。
    </p>
  </section>

  <section class="skills">
    <h2 class="section-title">スキル</h2>
    <div class="skill-list">
      {skills.map((skill) => (
        <div class="skill-card">
          <span class="skill-icon">{skill.icon}</span>
          <span class="skill-name">{skill.name}</span>
        </div>
      ))}
    </div>
  </section>

  {isAvailable && (
    <section class="available">
      <p class="available-text">📢 お仕事募集中！お気軽にお問い合わせください。</p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0;
  }

  .hero-image {
    margin-bottom: 1.5rem;
  }

  .profile-photo {
    border-radius: 50%;
    border: 4px solid #f0edff;
  }

  .hero-title {
    font-size: 2rem;
    color: #4f39fa;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #888;
  }

  .about {
    padding: 2rem 0;
  }

  .about-text {
    font-size: 1.05rem;
    color: #555;
    white-space: pre-line;
  }

  .skills {
    padding: 2rem 0;
  }

  .section-title {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #4f39fa;
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .skill-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background-color: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 0.75rem 1.25rem;
    font-size: 0.95rem;
    transition: box-shadow 0.2s;
  }

  .skill-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .skill-icon {
    font-size: 1.2rem;
  }

  .available {
    margin-top: 2rem;
    padding: 1.5rem;
    background-color: #f0edff;
    border-radius: 8px;
    text-align: center;
  }

  .available-text {
    color: #4f39fa;
    font-weight: bold;
  }
</style>