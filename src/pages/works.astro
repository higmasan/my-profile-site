---
import BaseLayout from '../layouts/BaseLayout.astro'
import WorkCard from '../components/WorkCard.astro'

import workCafe from '../assets/images/work-cafe.jpg'
import workBlog from '../assets/images/work-blog.jpg'
import workRecipe from '../assets/images/work-recipe.jpg'

const works = [
  {
    title: "カフェのWebサイト",
    description: "架空のカフェのコーポレートサイト。レスポンシブデザインで制作。",
    tags: ["HTML", "CSS", "JavaScript"],
    year: 2024,
    image: workCafe,
  },
  {
    title: "旅行ブログ",
    description: "旅行記を掲載するブログサイト。Markdownで記事を管理。",
    tags: ["Astro.js", "Markdown", "Tailwind CSS"],
    year: 2024,
    image: workBlog,
  },
  {
    title: "レシピ管理アプリ",
    description: "お気に入りのレシピを保存・検索できるWebアプリ。",
    tags: ["React", "CSS Modules"],
    year: 2023,
    image: workRecipe,
  },
]
---

<BaseLayout title="作品一覧 - 田中太郎のサイト">
  <h1>作品一覧</h1>

  <div class="works-grid">
    {works.map((work) => (
      <WorkCard
        title={work.title}
        description={work.description}
        tags={work.tags}
        year={work.year}
        image={work.image}
      />
    ))}
  </div>

  {works.length === 0 && (
    <p class="empty-message">まだ作品がありません。</p>
  )}
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    color: #4f39fa;
    margin-bottom: 1.5rem;
  }

  .works-grid {
    display: grid;
    gap: 1.5rem;
  }

  .empty-message {
    color: #888;
    text-align: center;
    padding: 3rem 0;
  }

  @media (min-width: 600px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>